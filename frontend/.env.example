# ============================================================
# Aisha Frontend — Environment Configuration
# Copy file này → đổi tên thành .env → điền giá trị thật
# Vite tự động load mọi biến VITE_* và inject vào import.meta.env
# ============================================================

# ── Backend API URL ─────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Google OAuth2 Client ID ─────────────────────────────────
# Phải khớp với GOOGLE_CLIENT_ID ở backend .env
# Tạo tại: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

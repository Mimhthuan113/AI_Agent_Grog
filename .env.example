# ============================================================
# Smart AI Home Hub — Environment Configuration
# Copy file này → đổi tên thành .env → điền giá trị thật
# KHÔNG commit file .env lên Git
# ============================================================

# ── APP ─────────────────────────────────────────────────────
APP_ENV=development            # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ── GROQ API (LLM) ──────────────────────────────────────────
# Đăng ký tại: https://console.groq.com (miễn phí, không cần thẻ)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL_DEFAULT=llama3-8b-8192         # Nhanh, 14,400 req/ngày
GROQ_MODEL_SMART=llama-3.3-70b-versatile  # Chất cao, 1,000 req/ngày
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.0
GROQ_TIMEOUT=10

# ── JWT AUTH ─────────────────────────────────────────────────
# Tạo bằng lệnh: openssl genrsa -out private.pem 2048
# Sau đó: openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ADMIN ACCOUNT (đổi ngay khi deploy) ─────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password_here

# ── GUEST ACCOUNT (read-only / hạn chế) ─────────────────────
# Guest chỉ được điều khiển đèn + đọc cảm biến (xem rbac.py)
GUEST_USERNAME=guest
GUEST_PASSWORD=guest123

# ── GOOGLE OAUTH2 LOGIN ─────────────────────────────────────
# Lấy tại: https://console.cloud.google.com/apis/credentials
# Tạo "OAuth 2.0 Client ID" (Web application) → copy Client ID
GOOGLE_CLIENT_ID=                   # 1024198xxx-xxx.apps.googleusercontent.com

# Email được cấp quyền Owner (cách nhau bằng dấu phẩy). Email khác → role guest.
ADMIN_EMAILS=owner@gmail.com,admin@gmail.com

# ── GOOGLE MAPS API (Reverse Geocoding) ─────────────────────
# Miễn phí $200/tháng (~28K requests). Để trống → fallback Nominatim/OpenStreetMap.
# Lấy tại: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# ── LANGFUSE (LLM Tracing — optional) ───────────────────────
# Để trống nếu không dùng. Đăng ký tại https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost           # docker: redis
REDIS_PORT=6379
REDIS_PASSWORD=                # Để trống nếu dev local
REDIS_DB=0

# ── DATABASE (Audit Log) ─────────────────────────────────────
SQLITE_DB_PATH=./data/audit.db

# ── HOME ASSISTANT ───────────────────────────────────────────
# Lấy token tại HA: Profile → Long-Lived Access Tokens
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxx
HA_TIMEOUT=5
HA_VERIFY_SSL=false

# ── MQTT ─────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost     # docker: mosquitto
MQTT_BROKER_PORT=8883          # TLS port (KHÔNG dùng 1883)
MQTT_USERNAME=smarthub
MQTT_PASSWORD=mqtt_password_here
MQTT_CA_CERT=./infrastructure/certs/ca.crt
MQTT_CLIENT_CERT=./infrastructure/certs/client.crt
MQTT_CLIENT_KEY=./infrastructure/certs/client.key

# ── ENCRYPTION ───────────────────────────────────────────────
# Tạo bằng: python -c "import secrets; print(secrets.token_hex(32))"
DB_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_PER_USER_PER_MINUTE=10
RATE_LIMIT_PER_ENTITY_PER_MINUTE=3
RATE_LIMIT_PER_USER_PER_HOUR=50
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SEC=60

# ── SECURITY ─────────────────────────────────────────────────
# Mặc định bao gồm:
#   - localhost web dev (Vite 5173, CRA 3000)
#   - capacitor://localhost  → Android WebView khi đóng gói APK với Capacitor
#   - https://localhost      → iOS WebView (Capacitor https scheme mặc định)
#   - ionic://localhost      → tương thích Ionic legacy
# Khi deploy production thêm domain thật ở đây, ví dụ: https://aisha.vn
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,capacitor://localhost,https://localhost,ionic://localhost
ALLOW_PLAIN_HTTP=true          # false trong production
